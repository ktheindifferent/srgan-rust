{
  "name": "@srgan-rust/sdk",
  "version": "0.2.0",
  "description": "JavaScript/TypeScript SDK for the SRGAN-Rust image upscaling API",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "image",
    "upscaling",
    "super-resolution",
    "srgan",
    "ai",
    "neural-network"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ktheindifferent/srgan-rust"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
