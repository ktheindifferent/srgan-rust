# SRGAN-Rust Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Security ──────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens for API authentication (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-string

# ── Server ────────────────────────────────────────────────────────────────────
# Host and port the API server listens on inside the container
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── Model paths ───────────────────────────────────────────────────────────────
# Directory containing .rsr model files and sidecar .json metadata
SRGAN_MODEL_PATH=/app/models

# Default model name to use when none is specified in the request
SRGAN_DEFAULT_MODEL=default

# ── Performance ───────────────────────────────────────────────────────────────
# Maximum parallel worker threads for batch and server processing
SRGAN_MAX_WORKERS=4

# Cache directory for upscaled images (leave empty to disable caching)
SRGAN_CACHE_DIR=/app/data/cache

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite connection string for job tracking (async upscale queue)
DATABASE_URL=sqlite:///app/data/srgan.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: error, warn, info, debug, trace
RUST_LOG=info

# Log format: text or json (json recommended for production log aggregators)
RUST_LOG_FORMAT=text

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum requests per minute per API key (0 = unlimited)
RATE_LIMIT_RPM=60

# ── Training ──────────────────────────────────────────────────────────────────
# Default training dataset directory
TRAINING_DATA_DIR=/app/training_data

# Default output directory for trained models
TRAINING_OUTPUT_DIR=/app/models
